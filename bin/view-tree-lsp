#!/usr/bin/env node
const path = require('path')

const args = process.argv.slice(2)
const command = args[0]

// CLI commands route to cli module
const cliCommands = ['create', 'help', '--help', '-h']

if (cliCommands.includes(command)) {
	const cliPath = path.join(__dirname, '..', 'out', 'cli', 'index.js')
	require(cliPath)
} else {
	// No args or --stdio → LSP server
	const serverPath = path.join(__dirname, '..', 'out', 'server', 'index.js')
	require(serverPath)
}
